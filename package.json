{
  "name": "tashil-ui",
  "version": "0.1.0",
  "description": "TashilUI — Swiss Army design system components on Radix UI + vanilla CSS Modules.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./styles/global.css": "./dist/styles/global.css",
    "./styles/themes/tashilpay.css": "./dist/styles/themes/tashilpay.css",
    "./styles/themes/zamyad.css": "./dist/styles/themes/zamyad.css",
    "./styles/themes/zhina.css": "./dist/styles/themes/zhina.css"
  },
  "scripts": {
    "sync-docs": "node scripts/sync-docs.mjs",
    "tokens": "node scripts/build-tokens.mjs",
    "icons": "node scripts/build-icons.mjs",
    "build": "pnpm run tokens && pnpm run icons && vite build && node scripts/copy-styles.mjs",
    "typecheck": "tsc --noEmit",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test-storybook": "vitest run",
    "test-storybook:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.1.8"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "playwright": "^1.61.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.4.6",
    "stylelint": "^16.14.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.9"
  }
}
